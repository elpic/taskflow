{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Taskflow Project Profile",
  "description": "Auto-detected project configuration used by all taskflow agents. Generated by the 'discover' workflow, read before every task.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "description": {
      "type": "string",
      "description": "Brief project description"
    },
    "discovered_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this profile was generated"
    },
    "languages": {
      "type": "object",
      "description": "Programming languages used",
      "properties": {
        "primary": { "type": "string" },
        "secondary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "package_manager": {
      "type": "object",
      "properties": {
        "tool": { "type": "string", "description": "e.g. uv, pnpm, cargo" },
        "config_file": { "type": "string" },
        "install_command": { "type": "string" },
        "add_command": { "type": "string" },
        "run_command": { "type": "string" },
        "lockfile": { "type": "string" }
      }
    },
    "linter": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "config_file": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "formatter": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "config_file": { "type": "string" },
        "command": { "type": "string" },
        "check_command": { "type": "string" }
      }
    },
    "type_checker": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "config_file": { "type": "string" },
        "command": { "type": "string" }
      }
    },
    "test_runner": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "test_directory": { "type": "string" },
        "coverage_command": { "type": "string" },
        "naming_convention": { "type": "string", "description": "e.g. test_*.py, *.test.ts" },
        "patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Testing patterns used: fixtures, mocking, factories, etc."
        }
      }
    },
    "architecture": {
      "type": "object",
      "properties": {
        "style": { "type": "string", "description": "e.g. hexagonal, layered, MVC, microservices" },
        "patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Design patterns used: repository, factory, observer, etc."
        },
        "module_boundaries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Key module/package boundaries"
        },
        "entry_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Main entry points of the application"
        }
      }
    },
    "conventions": {
      "type": "object",
      "properties": {
        "naming_style": { "type": "string", "description": "e.g. snake_case, camelCase" },
        "docstring_style": { "type": "string", "description": "e.g. Google, NumPy, Sphinx, JSDoc" },
        "line_length": { "type": "integer" },
        "import_style": { "type": "string", "description": "e.g. absolute, relative, grouped" },
        "error_handling": { "type": "string", "description": "e.g. exceptions, Result type, error codes" },
        "logging": { "type": "string", "description": "e.g. structlog, logging, console.log, tracing" },
        "type_annotations": { "type": "string", "description": "e.g. full, partial, none" }
      }
    },
    "ci_cd": {
      "type": "object",
      "properties": {
        "tool": { "type": "string", "description": "e.g. github-actions, gitlab-ci, jenkins" },
        "config_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Pipeline stages: lint, test, build, deploy"
        },
        "deployment_target": { "type": "string", "description": "e.g. vercel, aws, docker, k8s" }
      }
    },
    "containerization": {
      "type": "object",
      "properties": {
        "has_docker": { "type": "boolean" },
        "dockerfile": { "type": "string" },
        "compose_file": { "type": "string" },
        "base_image": { "type": "string" },
        "build_command": { "type": "string" },
        "run_command": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "framework": { "type": "string", "description": "e.g. FastAPI, Express, Gin, Actix" },
        "style": { "type": "string", "description": "e.g. REST, GraphQL, gRPC" },
        "database": { "type": "string", "description": "e.g. PostgreSQL, SQLite, MongoDB" },
        "orm": { "type": "string", "description": "e.g. SQLAlchemy, Prisma, Diesel" },
        "auth": { "type": "string", "description": "e.g. JWT, OAuth, session" },
        "external_services": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "project_structure": {
      "type": "object",
      "properties": {
        "layout": { "type": "string", "description": "e.g. src-layout, flat, monorepo" },
        "source_dirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_files": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Key files and their purpose: { 'main.py': 'entry point', 'config.py': 'settings' }"
        }
      }
    },
    "scripts": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Available commands: { 'dev': 'uv run uvicorn...', 'test': 'uv run pytest', 'lint': 'uv run ruff check .' }"
    }
  }
}
